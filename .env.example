# Cognitive Router Proxy — Environment Variables

# Provider API keys
ZAI_API_KEY=your_zai_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
GEMINI_API_KEY=your_gemini_key_here
# Ollama runs locally — no key needed

# Provider base URLs (override if you use a different endpoint or proxy)
# ZAI has two endpoints: /api/coding/paas/v4 (coding plan keys) and /api/paas/v4 (general keys)
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OLLAMA_BASE_URL=http://localhost:11434/v1

# Proxy configuration
ROUTER_PORT=3456
ROUTER_LOG_LEVEL=info
ROUTER_DB_PATH=data/cognitive-router.db

# Provider priority order (comma-separated, lower index = tried first)
ROUTER_PRIORITY=zai,openrouter,gemini,ollama

# Max VRAM for local models (GB) — models exceeding this are filtered out
ROUTER_VRAM_LIMIT=11

# Per-provider attempt timeouts (milliseconds)
# Keep these lower than the OpenClaw LLM request timeout so CogRouter can fail over first.
ROUTER_REQUEST_TIMEOUT_MS=55000
ROUTER_REMOTE_TIMEOUT_MS=12000
ROUTER_LOCAL_TIMEOUT_MS=20000
ROUTER_REMOTE_STREAM_TIMEOUT_MS=60000
ROUTER_LOCAL_STREAM_TIMEOUT_MS=60000

# Number of models to try within one provider before moving to the next provider.
ROUTER_MAX_ATTEMPTS_PER_PROVIDER=1

# Explicit fallback models used when a provider has no seeded registry model.
# Tool requests prefer provider priority order. Gemini is tool-capable, and
# Ollama is allowed only for explicitly listed local tool-capable models.
ROUTER_OPENROUTER_TOOL_MODEL=qwen/qwen3-coder:free
ROUTER_OPENROUTER_FALLBACK_MODEL=openrouter/owl-alpha
ROUTER_GEMINI_TOOL_MODEL=gemini-2.5-flash
ROUTER_GEMINI_FALLBACK_MODEL=gemini-2.5-flash
ROUTER_OLLAMA_TOOL_MODELS=gemma4:latest

# ─── LLM-as-Judge Feedback Loop ───
# After a fraction of successful responses, a judge model scores the quality.
# Scores feed back into model capability data via EMA, evolving over time.
# Set sample rate to 0 to disable.
ROUTER_JUDGE_SAMPLE_RATE=0.10
ROUTER_JUDGE_PROVIDER=openrouter
ROUTER_JUDGE_MODEL=qwen/qwen3-coder:free
ROUTER_JUDGE_MIN_LENGTH=50
ROUTER_JUDGE_MAX_CHARS=2000
ROUTER_JUDGE_TIMEOUT_MS=15000
